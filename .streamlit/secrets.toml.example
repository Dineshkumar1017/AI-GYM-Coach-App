GROQ_API_KEY = "your-groq-api-key"

[twilio]
# Recommended for Streamlit Community Cloud.
# Get these from https://console.twilio.com/ and keep them only in Streamlit Secrets.
TWILIO_ACCOUNT_SID = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN = "your-twilio-auth-token"

[webrtc]
# Optional fallback if you use a non-Twilio TURN provider.
TURN_URLS = ["turn:your-turn-host:3478", "turn:your-turn-host:443?transport=tcp"]
TURN_USERNAME = "your-turn-username"
TURN_CREDENTIAL = "your-turn-password"
