GROQ_API_KEY = "your-groq-api-key"

[webrtc]
# For Streamlit Community Cloud, add these in App settings -> Secrets.
# Use a real TURN provider for production; public relays can be slow or rate-limited.
TURN_URLS = ["turn:your-turn-host:3478", "turn:your-turn-host:443?transport=tcp"]
TURN_USERNAME = "your-turn-username"
TURN_CREDENTIAL = "your-turn-password"
